
{
  "entities": {
    "Farmer": {
      "title": "Farmer",
      "description": "A milk distribution supplier/farmer",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the farmer"
        },
        "canNumber": {
          "type": "string",
          "description": "Unique CAN number assigned to the farmer"
        },
        "accountNumber": {
          "type": "string",
          "description": "Bank account number for payments"
        },
        "active": {
          "type": "boolean",
          "description": "Whether the farmer is currently active"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["name", "canNumber"]
    },
    "MilkEntry": {
      "title": "Milk Entry",
      "description": "A daily milk collection or distribution record",
      "type": "object",
      "properties": {
        "farmerId": {
          "type": "string",
          "description": "Reference to the farmer ID"
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "Date of entry (YYYY-MM-DD)"
        },
        "session": {
          "type": "string",
          "enum": ["Morning", "Evening"],
          "description": "The session time"
        },
        "quantity": {
          "type": "number",
          "description": "Quantity of milk in Litres"
        },
        "kgWeight": {
          "type": "number",
          "description": "Original weight in Kilograms"
        },
        "fat": {
          "type": "number",
          "description": "Fat percentage"
        },
        "snf": {
          "type": "number",
          "description": "SNF percentage"
        },
        "rate": {
          "type": "number",
          "description": "Rate per litre"
        },
        "totalAmount": {
          "type": "number",
          "description": "Total amount for this entry"
        }
      },
      "required": ["farmerId", "date", "session", "quantity"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/farmers/{farmerId}": {
      "schema": "Farmer",
      "description": "Collection of milk farmers"
    },
    "/entries/{entryId}": {
      "schema": "MilkEntry",
      "description": "Daily milk entry records"
    }
  }
}
