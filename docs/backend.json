
{
  "entities": {
    "Customer": {
      "title": "Customer",
      "description": "A milk distribution customer",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the customer"
        },
        "canNumber": {
          "type": "string",
          "description": "Unique CAN number assigned to the customer"
        },
        "phoneNumber": {
          "type": "string",
          "description": "Contact phone number"
        },
        "active": {
          "type": "boolean",
          "description": "Whether the customer is currently active"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["name", "canNumber"]
    },
    "MilkEntry": {
      "title": "Milk Entry",
      "description": "A daily milk collection or distribution record",
      "type": "object",
      "properties": {
        "customerId": {
          "type": "string",
          "description": "Reference to the customer ID"
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "Date of entry (YYYY-MM-DD)"
        },
        "session": {
          "type": "string",
          "enum": ["Morning", "Evening"],
          "description": "The session time"
        },
        "quantity": {
          "type": "number",
          "description": "Quantity of milk in Litres"
        },
        "fat": {
          "type": "number",
          "description": "Fat percentage"
        },
        "snf": {
          "type": "number",
          "description": "SNF percentage"
        },
        "rate": {
          "type": "number",
          "description": "Rate per litre"
        },
        "totalAmount": {
          "type": "number",
          "description": "Total amount for this entry"
        }
      },
      "required": ["customerId", "date", "session", "quantity"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Collection of milk customers"
    },
    "/entries/{entryId}": {
      "schema": "MilkEntry",
      "description": "Daily milk entry records"
    }
  }
}
