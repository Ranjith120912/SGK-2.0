
{
  "entities": {
    "Farmer": {
      "title": "Farmer",
      "description": "A milk distribution supplier/farmer",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the farmer"
        },
        "canNumber": {
          "type": "string",
          "description": "Unique CAN number assigned to the farmer"
        },
        "bankAccountNumber": {
          "type": "string",
          "description": "Bank account number for payments"
        },
        "ifscCode": {
          "type": "string",
          "description": "Bank IFSC code"
        },
        "milkType": {
          "type": "string",
          "enum": ["COW", "BUFFALO"],
          "description": "Type of milk provided by the farmer"
        },
        "active": {
          "type": "boolean",
          "description": "Whether the farmer is currently active"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["name", "canNumber", "milkType"]
    },
    "Buyer": {
      "title": "Buyer",
      "description": "A customer who buys milk",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the buyer"
        },
        "buyerCode": {
          "type": "string",
          "description": "Unique code for the buyer"
        },
        "phone": {
          "type": "string",
          "description": "Contact phone number"
        },
        "active": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["name", "buyerCode"]
    },
    "MilkEntry": {
      "title": "Milk Entry",
      "description": "A daily milk collection record from a farmer",
      "type": "object",
      "properties": {
        "farmerId": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "session": {
          "type": "string",
          "enum": ["Morning", "Evening"]
        },
        "quantity": {
          "type": "number",
          "description": "Quantity in Litres"
        },
        "kgWeight": {
          "type": "number",
          "description": "Weight in Kg"
        },
        "rate": {
          "type": "number"
        },
        "totalAmount": {
          "type": "number"
        }
      }
    },
    "Sale": {
      "title": "Sale",
      "description": "A record of milk sold to a buyer",
      "type": "object",
      "properties": {
        "buyerId": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "session": {
          "type": "string",
          "enum": ["Morning", "Evening"]
        },
        "quantity": {
          "type": "number",
          "description": "Quantity in Litres"
        },
        "rate": {
          "type": "number"
        },
        "totalAmount": {
          "type": "number"
        }
      }
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "cowRate": {
          "type": "number"
        },
        "buffaloRate": {
          "type": "number"
        },
        "sellingRate": {
          "type": "number",
          "description": "Standard selling rate per litre"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/farmers/{farmerId}": {
      "schema": "Farmer",
      "description": "Collection of milk suppliers"
    },
    "/buyers/{buyerId}": {
      "schema": "Buyer",
      "description": "Collection of milk buyers"
    },
    "/entries/{entryId}": {
      "schema": "MilkEntry",
      "description": "Daily collection records"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Daily sales records"
    },
    "/settings/{settingsId}": {
      "schema": "Settings",
      "description": "Global settings"
    }
  }
}
