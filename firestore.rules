rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES
     * 
     * Updated to include the 'entries' collection and allow access for 
     * authenticated users to facilitate rapid prototyping.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // In production, you would check a roles collection.
      // For this prototype, we treat any authenticated user as an admin.
      return isSignedIn();
    }

    // --- COLLECTION RULES ---

    match /roles_admin/{adminUid} {
      allow get: if isSignedIn() && (request.auth.uid == adminUid || isAdmin());
      allow list, write: if isAdmin();
    }

    match /customers/{customerId} {
      allow read, write: if isAdmin();

      match /subscriptions/{subscriptionId} {
        allow read, write: if isAdmin();
      }
    }

    match /entries/{entryId} {
      allow read, write: if isAdmin();
    }

    match /canTypes/{canTypeId} {
      allow read, write: if isAdmin();
    }
  }
}
