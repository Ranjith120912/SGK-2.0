
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn();
    }
    match /farmers/{farmerId} {
      allow read, write: if isAdmin();
    }
    match /entries/{entryId} {
      allow read, write: if isAdmin();
    }
    match /buyers/{buyerId} {
      allow read, write: if isAdmin();
    }
    match /sales/{saleId} {
      allow read, write: if isAdmin();
    }
    match /settings/{settingsId} {
      allow read, write: if isAdmin();
    }
  }
}
